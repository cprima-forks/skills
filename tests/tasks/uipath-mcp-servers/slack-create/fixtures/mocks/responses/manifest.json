{
  "version": 2,
  "rules": [
    { "match": "or folders list",                                                                       "file": "or_folders_list.json" },
    { "match": "agenthub mcp list",                                                                     "file": "agenthub_mcp_list.json" },
    { "match": "agenthub mcp-tools list",                                                               "file": "agenthub_mcp_tools_list.json" },
    { "match": "agenthub mcp-tools candidates --category is-activity --name slack",                    "file": "candidates_by_name.json" },
    { "match": "agenthub mcp-tools candidates --category is-activity --connector uipath-salesforce-slack", "file": "candidates_by_connector.json" },
    { "match": "is connections list uipath-salesforce-slack",                                           "file": "connections_list.json" },
    { "match": "is resources describe uipath-salesforce-slack send_message_to_channel_v2 --connection-id conn-mock-slack-01 --operation Create", "file": "describe_op.json" },
    { "match": "is resources describe uipath-salesforce-slack send_message_to_channel_v2",              "file": "describe_no_op.json" },
    { "match": "is resources run list uipath-salesforce-slack curated_channels",                    "file": "run_list_channels.json" },
    { "match": "is resources run list uipath-salesforce-slack available_tokens",                    "file": "run_list_tokens.json" },
    { "match": "agenthub mcp-tools create-is-activity",                                                 "file": "create_dryrun.json" }
  ],
  "unmocked_default": {
    "response": "{\"Result\":\"Failure\",\"Message\":\"command not mocked\"}\n",
    "exit_code": 1
  }
}
