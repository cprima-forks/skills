{
  "version": 2,
  "rules": [
    { "match": "or folders list",                                                                          "file": "or_folders_list.json" },
    { "match": "agenthub mcp list",                                                                        "file": "agenthub_mcp_list.json" },
    { "match": "agenthub mcp-tools list",                                                                  "file": "agenthub_mcp_tools_list.json" },
    { "match": "agenthub mcp-tools candidates --category is-activity --name jira",                        "file": "candidates_by_name.json" },
    { "match": "agenthub mcp-tools candidates --category is-activity --connector uipath-atlassian-jira",  "file": "candidates_by_connector.json" },
    { "match": "is connections list uipath-atlassian-jira",                                                "file": "connections_list.json" },
    { "match": "is resources describe uipath-atlassian-jira curated_create_issue --connection-id conn-mock-jira-01 --operation Create -f fields.project.key=MOCKPROJ -f fields.issuetype.id=10", "file": "describe_cascade.json" },
    { "match": "is resources describe uipath-atlassian-jira curated_create_issue --connection-id conn-mock-jira-01 --operation Create", "file": "describe_op.json" },
    { "match": "is resources describe uipath-atlassian-jira curated_create_issue",                         "file": "describe_no_op.json" },
    { "match": "is resources run list uipath-atlassian-jira project",                                  "file": "run_list_project.json" },
    { "match": "is resources run list uipath-atlassian-jira issuetype",                                "file": "run_list_issuetype.json" },
    { "match": "agenthub mcp-tools create-is-activity",                                                    "file": "create_is_activity_dryrun.json" }
  ],
  "unmocked_default": {
    "response": "{\"Result\":\"Failure\",\"Message\":\"command not mocked in this scenario\"}\n",
    "exit_code": 1
  }
}
