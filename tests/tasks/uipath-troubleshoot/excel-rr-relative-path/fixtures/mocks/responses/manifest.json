    {
      "match": "or jobs history cc333333-9999-aaaa-bbbb-ccccddddeeee --output json",
      "file": "or-jobs-history-cc333399-output-json.json"
    },
    {
      "match": "or jobs logs \"cc333333-9999-aaaa-bbbb-ccccddddeeee\" --output json",
      "file": "or-jobs-logs-cc333399-output-json.json"
    },
    {
      "match": "or jobs logs cc333333-9999-aaaa-bbbb-ccccddddeeee --output json",
      "file": "or-jobs-logs-cc333399-output-json.json"
    }
  ]
