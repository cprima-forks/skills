{
  "version": 2,
  "_doc": "Synthetic fixtures for append-text-not-installed. Word Application Scope + Append Text faults at startup with REGDB_E_CLASSNOTREG because desktop Word is not installed on the server.",
  "rules": [
    {
      "match": "or folders list --output json",
      "file": "or-folders-list-output-json.json"
    },
    {
      "match": "or jobs list --folder-key \"f4a5b6c7-d8e9-4193-c4a5-b6c7d8e9f001\" --state Faulted --output json",
      "file": "or-jobs-list-folder-key-f4a5b6c7-state-faulted-output-json.json"
    },
    {
      "match": "or jobs list --folder-key f4a5b6c7-d8e9-4193-c4a5-b6c7d8e9f001 --state Faulted --output json",
      "file": "or-jobs-list-folder-key-f4a5b6c7-state-faulted-output-json.json"
    },
    {
      "match": "or jobs get \"a5b6c7d8-e9f0-4204-d5b6-c7d8e9f00112\" --output json",
      "file": "or-jobs-get-a5b6c7d8-output-json.json"
    },
    {
      "match": "or jobs get a5b6c7d8-e9f0-4204-d5b6-c7d8e9f00112 --output json",
      "file": "or-jobs-get-a5b6c7d8-output-json.json"
    },
    {
      "match": "or jobs logs \"a5b6c7d8-e9f0-4204-d5b6-c7d8e9f00112\" --level Error --output json",
      "file": "or-jobs-logs-a5b6c7d8-level-error-output-json.json"
    },
    {
      "match": "or jobs logs a5b6c7d8-e9f0-4204-d5b6-c7d8e9f00112 --level Error --output json",
      "file": "or-jobs-logs-a5b6c7d8-level-error-output-json.json"
    },
    {
      "match": "or jobs logs \"a5b6c7d8-e9f0-4204-d5b6-c7d8e9f00112\" --output json",
      "file": "or-jobs-logs-a5b6c7d8-output-json.json"
    },
    {
      "match": "or jobs logs a5b6c7d8-e9f0-4204-d5b6-c7d8e9f00112 --output json",
      "file": "or-jobs-logs-a5b6c7d8-output-json.json"
    },
    {
      "match": "docsai ask",
      "passthrough": true,
      "_doc": "Proxy open-ended docsai queries to the real uip CLI; cache results in _cache/."
    }
  ],
  "unmocked_default": {
    "response": "[]\n",
    "exit_code": 0,
    "_doc": "Permissive fallback for unmatched commands."
  }
}
