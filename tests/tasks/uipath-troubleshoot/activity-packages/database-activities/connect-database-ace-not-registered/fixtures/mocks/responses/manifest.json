{
  "version": 2,
  "_doc": "Synthetic fixtures hand-authored from the connect-to-database-failures playbook (branch 2: provider not registered / bitness mismatch). Replace with verbatim captures from a real .local/investigations/ before treating as a regression signal (see ../_shared/scripts/generate_scenario.py).",
  "rules": [
    {
      "match": "or folders list --output json",
      "file": "or-folders-list-output-json.json"
    },
    {
      "match": "or jobs list --folder-key \"7c1f2e9a-4b6d-4a8e-9f3c-2d5e6a7b8c9d\" --state Faulted --output json",
      "file": "or-jobs-list-folder-key-7c1f2e9a-state-faulted-output-json.json"
    },
    {
      "match": "or jobs list --folder-key 7c1f2e9a-4b6d-4a8e-9f3c-2d5e6a7b8c9d --state Faulted --output json",
      "file": "or-jobs-list-folder-key-7c1f2e9a-state-faulted-output-json.json"
    },
    {
      "match": "or jobs get \"3b8d5c2e-1a4f-4e6c-8b9d-5c7a2e3f4b6d\" --output json",
      "file": "or-jobs-get-3b8d5c2e-output-json.json"
    },
    {
      "match": "or jobs get 3b8d5c2e-1a4f-4e6c-8b9d-5c7a2e3f4b6d --output json",
      "file": "or-jobs-get-3b8d5c2e-output-json.json"
    },
    {
      "match": "or jobs logs \"3b8d5c2e-1a4f-4e6c-8b9d-5c7a2e3f4b6d\" --level Error --output json",
      "file": "or-jobs-logs-3b8d5c2e-level-error-output-json.json"
    },
    {
      "match": "or jobs logs 3b8d5c2e-1a4f-4e6c-8b9d-5c7a2e3f4b6d --level Error --output json",
      "file": "or-jobs-logs-3b8d5c2e-level-error-output-json.json"
    },
    {
      "match": "or jobs logs \"3b8d5c2e-1a4f-4e6c-8b9d-5c7a2e3f4b6d\" --output json",
      "file": "or-jobs-logs-3b8d5c2e-level-error-output-json.json"
    },
    {
      "match": "or jobs logs 3b8d5c2e-1a4f-4e6c-8b9d-5c7a2e3f4b6d --output json",
      "file": "or-jobs-logs-3b8d5c2e-level-error-output-json.json"
    },
    {
      "match": "docsai ask",
      "passthrough": true,
      "_doc": "Proxy open-ended docsai queries to the real uip CLI; cache results in _cache/."
    }
  ],
  "unmocked_default": {
    "response": "[]\n",
    "exit_code": 0,
    "_doc": "Permissive fallback: any uip command not matched returns []. Lets the agent explore beyond the recorded path."
  }
}
