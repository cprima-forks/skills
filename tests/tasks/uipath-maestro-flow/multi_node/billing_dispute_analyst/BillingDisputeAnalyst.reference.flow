    {
      "nodeType": "uipath.agent.resource.context.index.billing-dispute-sop-index.cc45b9b4-dbf6-47b3-40ac-08debc0cec5b",
      "version": "1.0.0",
      "category": "agent",
      "tags": [
        "agent-context",
        "index"
      ],
      "description": "SOP grounding for the Billing Dispute Analyst agent.",
      "sortOrder": 505,
      "display": {
        "label": "Billing Dispute SOP Index",
        "description": "SOP grounding for the Billing Dispute Analyst agent.",
        "icon": "file-text",
        "shape": "circle"
      },
      "handleConfiguration": [
        {
          "position": "top",
          "handles": [
            {
              "id": "input",
              "type": "target",
              "handleType": "artifact",
              "constraints": {
                "allowedSources": [
                  {
                    "nodeType": "uipath.agent.autonomous",
                    "handleId": "context"
                  },
                  {
                    "nodeType": "uipath.agent.conversational",
                    "handleId": "context"
                  }
                ],
                "validationMessage": "Only Agent's context handle can connect here"
              }
            }
          ]
        }
      ],
      "model": {
        "source": true
      },
      "form": {
        "id": "context-index-form",
        "title": "Context Index",
        "sections": [
          {
            "id": "index-settings",
            "title": "Index Settings",
            "collapsible": true,
            "defaultExpanded": true,
            "fields": [
              {
                "name": "inputs.retrievalMode",
                "type": "custom",
                "component": "index-strategy-select",
                "label": "Strategy",
                "componentProps": {
                  "options": [
                    {
                      "value": "semantic",
                      "label": "Semantic"
                    },
                    {
                      "value": "structured",
                      "label": "Structured",
                      "preview": true
                    },
                    {
                      "value": "deeprag",
                      "label": "DeepRAG"
                    },
                    {
                      "value": "batchtransform",
                      "label": "Batch Transform",
                      "preview": true
                    }
                  ]
                }
              },
              {
                "name": "inputs.query",
                "type": "custom",
                "component": "context-query-editor",
                "label": "Query",
                "componentProps": {
                  "placeholder": "The query for the Semantic strategy."
                },
                "rules": [
                  {
                    "id": "show-query-semantic",
                    "conditions": [
                      {
                        "when": "inputs.retrievalMode",
                        "is": "semantic"
                      }
                    ],
                    "effects": {
                      "visible": true
                    }
