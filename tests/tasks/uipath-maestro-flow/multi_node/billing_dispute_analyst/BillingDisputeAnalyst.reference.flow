    {
      "id": "disputeAnalyst",
      "type": "uipath.agent.autonomous",
      "typeVersion": "1.1",
      "display": {
        "label": "Dispute Analyst Agent",
        "subLabel": "Analyzes the dispute grounded on the SOP index.",
        "shape": "rectangle",
        "icon": "autonomous-agent"
      },
      "inputs": {
        "systemPrompt": "Analyze the billing dispute using the SOP guidance.",
        "userPrompt": "Analyze the dispute from the provided facts and SOP context.",
        "source": "e5715a3f-0d31-4ad8-9c70-91df180760e6",
        "agentInputVariables": [],
        "agentOutputVariables": [
          {
            "id": "determination",
            "type": "string",
            "description": "SOP-based determination for the dispute"
          },
          {
            "id": "rationale",
            "type": "string",
            "description": "Why this determination, citing the SOP"
          }
        ]
      },
      "outputs": {
        "error": {
          "type": "object",
          "description": "Error information if the node fails",
          "source": {
            "type": "literal",
            "expression": "=Error",
            "fieldType": "string"
          },
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
