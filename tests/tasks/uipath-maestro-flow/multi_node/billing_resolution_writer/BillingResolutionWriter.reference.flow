  "name": "ResolutionWriter",
  "runtime": "maestro",
  "nodes": [
    {
      "id": "start",
      "type": "core.trigger.manual",
      "typeVersion": "1.0",
      "display": {
        "label": "Manual trigger"
      },
      "inputs": {
        "entryPointId": "cd3aa493-b55d-4226-b548-156213beb7c3",
        "isDefaultEntryPoint": true
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "Data passed when manually triggering the workflow.",
          "source": "null",
          "var": "output"
        }
      }
    },
    {
      "id": "resolutionWriter",
      "type": "uipath.agent.autonomous",
      "typeVersion": "1.1",
      "display": {
        "label": "Resolution Writer Agent",
        "subLabel": "Writes the dispute resolution email.",
        "shape": "rectangle",
        "icon": "autonomous-agent"
      },
      "inputs": {
        "systemPrompt": "Write a billing dispute resolution email.",
        "userPrompt": "Write the resolution email from the provided dispute facts.",
        "source": "75b07752-c283-4ede-b4e5-f4961d0dca77",
        "agentInputVariables": [],
        "agentOutputVariables": [
          {
            "id": "subject",
            "type": "string",
            "description": "subject for the email"
          },
          {
            "id": "body",
            "type": "string",
            "description": "body of the email"
          }
        ]
      },
      "outputs": {
        "error": {
          "type": "object",
          "description": "Error information if the node fails",
          "source": {
            "type": "literal",
            "expression": "=Error",
            "fieldType": "string"
          },
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "id": "doneSuccess",
      "type": "core.control.end",
      "typeVersion": "1.0",
      "display": {
        "label": "Done"
      },
      "inputs": {},
      "outputs": {
        "emailSubject": {
          "source": {
            "type": "jsExpression",
            "expression": "$vars.resolutionWriter.output.subject",
            "fieldType": "string"
          }
        },
        "emailBody": {
          "source": {
            "type": "jsExpression",
            "expression": "$vars.resolutionWriter.output.body",
            "fieldType": "string"
          }
        }
      }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "sourceNodeId": "start",
      "sourcePort": "output",
      "targetNodeId": "resolutionWriter",
      "targetPort": "input"
    },
