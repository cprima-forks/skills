  "variables": {
    "globals": [
      {
        "id": "disputedInvoice",
        "direction": "in",
        "type": "file",
        "defaultValue": "invoice-MCS-2026-04872.pdf",
        "description": "Invoice the customer is disputing",
        "triggerNodeId": "start"
      },
      {
        "id": "webhookPayload",
        "direction": "in",
        "type": "object",
        "schema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "description": "Schema for a billing dispute submission event.",
          "properties": {
            "event": {
              "type": "string",
              "description": "The type of event being recorded.",
              "enum": [
                "billing_dispute_submitted"
              ]
            },
            "timestamp": {
              "type": "string",
              "format": "date-time",
              "description": "The date and time the event occurred."
            },
            "disputeId": {
              "type": "string",
              "description": "Unique identifier for the dispute."
            },
            "customer": {
              "type": "object",
              "description": "Details about the customer submitting the dispute.",
              "properties": {
                "companyName": {
                  "type": "string",
                  "description": "The name of the customer's company."
                },
                "accountNumber": {
                  "type": "string",
                  "description": "The customer's account number."
                },
                "contactName": {
                  "type": "string",
                  "description": "Name of the customer's contact person."
                },
                "contactEmail": {
                  "type": "string",
                  "format": "email",
                  "description": "Email address of the customer's contact person."
                },
                "contactPhone": {
                  "type": "string",
                  "description": "Phone number of the customer's contact person."
                },
                "address": {
                  "type": "object",
                  "description": "The customer's address.",
                  "properties": {
                    "street": {
                      "type": "string",
                      "description": "Street portion of the address."
                    },
                    "city": {
                      "type": "string",
                      "description": "City portion of the address."
                    },
                    "state": {
                      "type": "string",
                      "description": "State portion of the address."
                    },
                    "zipCode": {
                      "type": "string",
                      "description": "Postal code portion of the address."
                    }
                  },
                  "required": [
                    "street",
                    "city",
                    "state",
                    "zipCode"
                  ]
                }
              },
              "required": [
                "companyName",
                "accountNumber",
                "contactName",
                "contactEmail",
                "address"
              ]
            },
            "invoice": {
              "type": "object",
              "description": "Details about the invoice being disputed.",
              "properties": {
                "invoiceNumber": {
                  "type": "string",
                  "description": "The number of the invoice."
                },
                "invoiceDate": {
                  "type": "string",
                  "format": "date",
                  "description": "The date the invoice was issued."
                },
                "dueDate": {
                  "type": "string",
                  "format": "date",
                  "description": "The date the invoice is due."
                },
                "billingPeriod": {
                  "type": "object",
                  "description": "The billing period covered by the invoice.",
                  "properties": {
                    "start": {
                      "type": "string",
                      "format": "date",
                      "description": "Start date of the billing period."
                    },
                    "end": {
                      "type": "string",
                      "format": "date",
                      "description": "End date of the billing period."
                    }
                  },
                  "required": [
                    "start",
                    "end"
                  ]
                },
                "totalAmount": {
                  "type": "number",
                  "description": "The total amount of the invoice."
                },
                "currency": {
                  "type": "string",
                  "description": "The currency of the invoice amount."
                },
                "vendor": {
                  "type": "object",
                  "description": "Details about the vendor issuing the invoice.",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "The name of the vendor."
                    },
                    "address": {
                      "type": "string",
                      "description": "The address of the vendor."
                    },
                    "email": {
                      "type": "string",
                      "format": "email",
                      "description": "Email address of the vendor."
                    }
                  },
                  "required": [
                    "name",
                    "address",
                    "email"
                  ]
                }
              },
              "required": [
                "invoiceNumber",
                "invoiceDate",
                "dueDate",
                "billingPeriod",
                "totalAmount",
                "currency",
                "vendor"
              ]
            },
            "dispute": {
              "type": "object",
              "description": "Details about the dispute.",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "The type of dispute."
                },
