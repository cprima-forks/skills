{
  "id": "98fabe45-b2f1-4fff-8799-f833f35f9654",
  "version": "1.6",
  "name": "BillingDisputeResolution",
  "runtime": "maestro",
  "nodes": [
    {
      "id": "start",
      "type": "core.trigger.manual",
      "typeVersion": "1.0",
      "display": {
        "label": "Manual Trigger"
      },
      "inputs": {
        "entryPointId": "109d8a4f-06d7-4830-85dd-7bf1536c0717"
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "Data passed when manually triggering the workflow.",
          "source": "null",
          "var": "output"
        }
      }
    },
    {
      "id": "dataTransform",
      "type": "core.action.script",
      "typeVersion": "1.0",
      "display": {
        "label": "Normalize Data",
        "subLabel": ""
      },
      "inputs": {
        "script": "const FIELD_TYPE = {\n  Text: 0, Number: 1, Date: 2, Name: 3, Address: 4, Keyword: 5,\n  Set: 6, Boolean: 7, Table: 9, Internal: 10, FieldGroup: 11, MonetaryQuantity: 12,\n};\nconst typeCode = (t) => (typeof t === \"number\" ? t : FIELD_TYPE[t] ?? 0);\nconst typeName = (t) => (typeof t === \"string\" ? t : Object.keys(FIELD_TYPE).find(k => FIELD_TYPE[k] === t));\nconst isLeafComponent = (c) => c && typeof c === \"object\" && \"FieldId\" in c && \"FieldName\" in c;\nconst unwrapV1TableBody = (firstValue) => {\n  const comps = firstValue?.Components ?? [];\n  const body = comps.find(c => c.FieldName !== \"Header\" && typeName(c.FieldType) === \"Internal\");\n  const header = comps.find(c => c.FieldName === \"Header\");\n  if (body && header) return body.Values ?? [];\n  return null;\n};\n\nconst projectComponent = (c) => {\n  if (c.IsMissing) {\n    return { Id: c.FieldId, Name: c.FieldName, Value: null, UnformattedValue: null, Confidence: null, OcrConfidence: null, Type: typeCode(c.FieldType) };\n  }\n  const v = c.Values?.[0];\n  return {\n    Id: c.FieldId,\n    Name: c.FieldName,\n    Value: v?.Value ?? null,\n    UnformattedValue: v?.UnformattedValue ?? null,\n    Confidence: v?.Confidence ?? null,\n    OcrConfidence: v?.OcrConfidence ?? null,\n    Type: typeCode(c.FieldType),\n  };\n};\n\nconst extractionResult = $vars.invoiceExtraction.output.ExtractionResult;\nconst fields = extractionResult?.ResultsDocument?.Fields ?? [];\n\nconst FieldGroups = [];\n\nfor (const fg of fields) {\n  if (fg.IsMissing) continue;\n  const values = fg.Values ?? [];\n  if (values.length === 0) continue;\n  const firstValue = values[0];\n  const firstComps = firstValue?.Components ?? [];\n  if (firstComps.length === 0 || !firstComps.some(isLeafComponent)) continue;\n  const v1Rows = unwrapV1TableBody(firstValue);\n  const rows = v1Rows ?? values;\n  for (const row of rows) {\n    FieldGroups.push({\n      FieldGroupName: fg.FieldName,\n      FieldValues: (row.Components ?? []).map(projectComponent),\n    });\n  }\n}\n\nconst webhookPayloadKeyValues = (() => {\n  const extractKeyValues = (obj, prefix = \"\") => {\n    return Object.entries(obj).reduce((acc, [key, value]) => {\n      const fullKey = prefix ? `${prefix}.${key}` : key;\n      if (value && typeof value === \"object\" && !Array.isArray(value)) {\n        return { ...acc, ...extractKeyValues(value, fullKey) };\n      }\n      acc[fullKey] = value;\n      return acc;\n    }, {});\n  };\n  return extractKeyValues($vars.start.output.webhookPayload);\n})();\n\nreturn { FieldGroups, WebhookPayloadKeyValues: webhookPayloadKeyValues };"
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "The return value of the script",
          "source": "=result.response",
          "var": "output"
        },
        "error": {
          "type": "object",
          "description": "Error information if the script fails",
          "source": "=Error",
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "id": "discrepancyScript",
      "type": "core.action.script",
      "typeVersion": "1.0",
      "display": {
        "label": "Discrepancy Detection",
        "subLabel": ""
      },
      "inputs": {
        "script": "const extractedLineItems = $vars.start?.output?.webhookPayload?.dispute?.disputedLineItems || [];\nconst erpContractItems = $vars.queryEntityRecords2?.output || [];\nconst crmRecords = $vars.queryEntityRecords1?.output || [];\n\nlet pricingMismatches = [];\nlet totalOvercharge = 0;\nlet totalUndercharge = 0;\n\nfor (const extractedItem of extractedLineItems) {\n  const contractItem = erpContractItems.find(item => item.lineNumber === extractedItem.lineNumber);\n\n  if (\n    extractedItem.unitPrice !== undefined &&\n    extractedItem.quantity !== undefined &&\n    contractItem?.amount !== undefined &&\n    (extractedItem.unitPrice * Number(extractedItem.quantity)) !== contractItem.amount\n  ) {\n    const lineDifference = (extractedItem.unitPrice * Number(extractedItem.quantity)) - contractItem.amount;\n    pricingMismatches.push({\n      lineItem: extractedItem.description,\n      invoicedUnitPrice: extractedItem.unitPrice,\n      contractUnitPrice: contractItem.amount / Number(extractedItem.quantity) || null,\n      difference: lineDifference,\n      lineTotalInvoiced: extractedItem.unitPrice * Number(extractedItem.quantity),\n      lineTotalContract: contractItem.amount,\n    });\n    if (lineDifference > 0) {\n      totalOvercharge += lineDifference;\n    } else {\n      totalUndercharge += Math.abs(lineDifference);\n    }\n  }\n}\n\nconst discrepancyCount = pricingMismatches.length;\n\nconst erpDetails = erpContractItems.map(item => ({\n  lineNumber: item.lineNumber,\n  amount: item.amount,\n  description: item.description\n}));\n\nconst crmDetails = crmRecords.map(record => ({\n  accountManagerName: record.accountManagerName,\n  accountName: record.accountName,\n  accountNumber: record.accountNumber,\n  accountTier: record.accountTier\n}));\n\nconst originalData = $vars.start?.output?.webhookPayload?.dispute || {};\nconst vendorDetails = $vars.start?.output?.webhookPayload?.invoice?.vendor || {};\nconst invoiceDetails = $vars.start?.output?.webhookPayload?.invoice || {};\nconst configDetails = $vars.start?.output?.webhookPayload?.config || {};\nconst erpLookupData = erpDetails;\n\nconst pertinentInfo = {\n  erpDetails,\n  crmDetails,\n  disputeInformation: originalData,\n  vendorDetails,\n  invoiceDetails,\n  configDetails,\n  erpLookupData\n};\n\nreturn {\n  pricingMismatches,\n  duplicateInvoice: false,\n  missingDiscounts: [],\n  totalOvercharge,\n  totalUndercharge,\n  discrepancyCount,\n  summary: discrepancyCount > 0\n    ? `${discrepancyCount} discrepancies found. Overcharge: ${totalOvercharge}, Undercharge: ${totalUndercharge}`\n    : \"No discrepancies found\",\n  pertinentDetails: pertinentInfo,\n};"
      },
      "outputs": {
        "output": {
          "type": "object",
          "description": "The return value of the script",
          "source": "=result.response",
          "var": "output"
        },
        "error": {
          "type": "object",
          "description": "Error information if the script fails",
          "source": "=Error",
          "var": "error",
          "schema": {
            "$schema": "http://json-schema.org/draft-07/schema#",
            "type": "object",
            "required": [
              "code",
              "message",
              "detail",
              "category",
              "status"
            ],
            "properties": {
              "code": {
                "type": "string",
                "description": "Error code as a string"
              },
              "message": {
                "type": "string",
                "description": "High-level error message"
              },
              "detail": {
                "type": "string",
                "description": "Detailed error description"
              },
              "category": {
                "type": "string",
                "description": "Error category"
              },
              "status": {
                "type": "integer",
                "description": "HTTP status code"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "id": "switchValidity",
      "type": "core.logic.switch",
      "typeVersion": "1.0",
      "display": {
        "label": "Route by Validity",
        "subLabel": ""
      },
      "inputs": {
        "cases": [
          {
            "id": "mpvf342q-n9bnw",
            "label": "Valid (High)",
            "expression": {
              "type": "jsExpression",
              "expression": "$vars.autonomousAgent1.output.recommendedAction === \"escalate_to_manager\"",
              "fieldType": "boolean"
            }
          },
          {
            "id": "morkhbns-akqym",
            "label": "Valid (Low)",
            "expression": "$vars.autonomousAgent1.output.recommendedAction === \"auto_resolve\""
          },
          {
            "id": "morkhg86-6qcdh",
            "label": "Reject",
            "expression": "$vars.autonomousAgent1.output.recommendedAction === \"reject\""
          }
        ],
        "hasDefault": false
      }
    },
    {
      "id": "decisionApproval",
      "type": "core.logic.decision",
      "typeVersion": "1.0",
      "display": {
        "label": "Manager Approved?",
        "subLabel": ""
      },
      "inputs": {
        "expression": "false",
        "trueLabel": "Rejected",
        "falseLabel": "Approved"
      }
    },
    {
      "id": "merge1",
      "type": "core.logic.merge",
      "typeVersion": "1.0",
      "display": {
        "label": "Merge",
        "icon": "merge"
      },
      "inputs": {}
    },
    {
      "id": "queryEntityRecords1",
      "type": "uipath.connector.uipath-uipath-dataservice.query-entity-records",
      "typeVersion": "1.0.0",
      "display": {
        "label": "CRM Lookup",
        "subLabel": "",
        "icon": "https://staging.uipath.com/a1f40477-e00b-40a8-8513-1e7d46c7dc31/studio_/typecache/icons/98381fa079bbcf73264f551006d6ef7580fb53992f3d9f94361eb5d9e06040cb.svg",
        "description": "(Data Fabric) Retrieves a list of records for the selected Entity from Data Fabric, according to specified filters."
      },
      "inputs": {
        "detail": {
          "connector": "uipath-uipath-dataservice",
          "connectionId": "d61e5d0e-04af-4f93-95cc-151d81fa08dc",
          "connectionResourceId": "d61e5d0e-04af-4f93-95cc-151d81fa08dc",
          "connectionFolderKey": "c4359cde-55f0-4f0e-9322-c6cdce74ab4c",
          "method": "POST",
          "endpoint": "/v2/{entityName}/qer",
          "pathParameters": {
            "entityName": "BillingDisputeCRM"
          },
          "queryParameters": {
            "queryExpression": "=js:(`accountNumber = '${$vars.start.output.webhookPayload.customer.accountNumber}'`)",
            "limit": 100,
            "expansionLevel": "3",
            "isAscending": false,
            "start": 0
          },
          "configuration": "=jsonString:{\"essentialConfiguration\":{\"connectorVersion\":\"1.65.1\",\"executionType\":null,\"customFieldsRequestDetails\":{\"objectActionName\":\"GenerateSchema\",\"parameterValues\":[[\"entityName\",\"BillingDisputeCRM\"]]},\"instanceParameters\":{\"connectorKey\":\"uipath-uipath-dataservice\",\"objectName\":\"QueryEntityRecordsCurated\",\"httpMethod\":\"POST\",\"activityType\":\"Curated\",\"version\":\"1.0.0\",\"supportsStreaming\":false,\"subType\":\"standard\"},\"objectName\":\"QueryEntityRecordsCurated\",\"operation\":\"list\",\"packageVersion\":\"1.0.0\",\"httpMethod\":\"POST\",\"path\":\"/v2/{entityName}/qer\",\"unifiedTypesCompatible\":true},\"optionalConfiguration\":{\"_textBlocks\":[{\"name\":\"schemaAPIErrorMessage\",\"text\":\"Could not generate schema for the chosen entity.\",\"severity\":\"error\"}],\"objectActions\":[{\"actionType\":\"api\",\"rules\":[{\"type\":\"path\",\"refFieldName\":\"entityName\",\"refFieldValues\":[\"*\"],\"isCleared\":false,\"isVariable\":false}],\"name\":\"GenerateSchema\",\"apiConfiguration\":{\"url\":\"/standard-objects/{entityName}/qer/metadata\",\"method\":\"GET\"},\"onSuccess\":{\"type\":\"remap\",\"remapConfiguration\":{\"input\":\"replace\",\"output\":\"replace\"}},\"onFailure\":{\"type\":\"remap\",\"remapConfiguration\":{\"input\":\"noop\",\"output\":\"noop\"},\"actions\":[{\"actionType\":\"showMessages\",\"refFieldName\":\"entityName\",\"messages\":[\"schemaAPIErrorMessage\"]}]}},{\"actionType\":\"reset\",\"rules\":[{\"type\":\"path\",\"refFieldName\":\"entityName\",\"isCleared\":true,\"isVariable\":false}],\"name\":\"ClearContent\"}],\"connectorName\":\"Data Fabric\",\"maxPageSize\":null,\"jobArguments\":null,\"isAutopilotInvalidConfig\":false,\"additionalHeaders\":null,\"cachedLookupValues\":[[\"entityName\",[{\"id\":\"BillingDisputeCRM\",\"displayColumns\":[\"BillingDisputeCRM\"],\"stringFormatDisplayColumns\":\"\"}]]],\"cachedBrowserItems\":[],\"cachedPropertyMappings\":[],\"primar